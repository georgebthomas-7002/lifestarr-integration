# --- Database (Neon Postgres via Vercel Marketplace) ---
# Auto-provisioned when you attach Neon to the project from the Vercel Storage tab.
# Locally: run `vercel env pull .env.local` to sync.
DATABASE_URL=
DATABASE_URL_UNPOOLED=
PGHOST=
PGUSER=
PGDATABASE=
PGPASSWORD=

# --- Auth.js v5 ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# Local: http://localhost:3000   Prod: https://lifestarr-integration.vercel.app
AUTH_URL=http://localhost:3000

# --- Resend (magic-link email) ---
# Get from https://resend.com/api-keys
AUTH_RESEND_KEY=
# Verified sender. Use Resend's onboarding@resend.dev for sandboxed testing.
RESEND_FROM_EMAIL=

# Comma-separated email allowlist for dashboard sign-in.
ALLOWED_EMAILS=george@sidekickstrategies.com,joe@lifestarr.com

# --- Mighty Networks webhook ---
# Generate a strong random string. Mighty sends this as `Authorization: Bearer <secret>`.
MIGHTY_WEBHOOK_SECRET=
# Optional: Mighty REST API token if any handlers need to look up data Mighty doesn't include in payloads.
MIGHTY_API_TOKEN=

# --- HubSpot ---
# Private app token. See docs/hubspot-setup.md.
HUBSPOT_API_TOKEN=
# Pipeline + initial stage IDs. Find in HubSpot → Settings → Pipelines.
HUBSPOT_CUSTOMER_PIPELINE_ID=
HUBSPOT_NEW_PURCHASE_STAGE_ID=
# Owner id new contacts get assigned to. Look up via `client.crm.owners.ownersApi.getPage()`.
# Optional — leave blank if you don't want default-owner assignment.
HUBSPOT_DEFAULT_CONTACT_OWNER_ID=

# --- Alerting ---
# Where to send "handler failed 3x" alerts.
ALERT_EMAIL=
